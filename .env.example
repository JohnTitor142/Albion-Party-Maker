# Supabase Configuration
# Obtenez ces valeurs depuis votre projet Supabase: https://supabase.com/dashboard
# Allez dans Settings > API

# 1. Project URL (en haut de la page API)
SUPABASE_URL=https://xxxxx.supabase.co

# 2. API Keys > Publishable (clé publique, anciennement "anon")
SUPABASE_ANON_KEY=eyJhbGc...your-publishable-key-here

# 3. API Keys > Secret (clé secrète, anciennement "service_role")
SUPABASE_SERVICE_KEY=eyJhbGc...your-secret-key-here

# ⚠️ IMPORTANT: La Secret key est sensible et ne doit JAMAIS être exposée publiquement
# Utilisez-la uniquement côté serveur pour les opérations admin
